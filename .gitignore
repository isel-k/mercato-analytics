# dlt secrets
.dlt/secrets.toml
.dlt/*.p8

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# dbt
dbt/target/
dbt/dbt_packages/
dbt/logs/
dbt/.user.yml

# Airflow / Astro
# orchestration/.astro/ has its own precise .gitignore (config.yaml,
# dag_integrity_exceptions.txt etc. are meant to be committed — only
# */standalone/ and *.local.y*ml are local machine state).
orchestration/logs/
orchestration/**/__pycache__/

# Evidence
dashboard/node_modules/
dashboard/.evidence/
dashboard/build/

# Env / secrets
.env
.env.*
!.env.example

# OS / editor
.DS_Store
.vscode/
.idea/
