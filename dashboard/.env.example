# Copy to dashboard/.env (gitignored) and fill in real values.
# dashboard/.env must NEVER be committed.
# Non-secret connection fields live in sources/mercato_analytics/connection.yaml;
# these three are the ones the Evidence Snowflake connector marks as secret.

EVIDENCE_SOURCE__mercato_analytics__username=PIPELINE_SVC
# Multi-line PEM content: wrap in double quotes with literal \n between lines
# (dotenv unescapes \n to a real newline when loading this file).
EVIDENCE_SOURCE__mercato_analytics__private_key="<PEM content, \n-joined>"
EVIDENCE_SOURCE__mercato_analytics__passphrase=<key_passphrase>
