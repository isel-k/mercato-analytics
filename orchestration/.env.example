# Copy to orchestration/.env (gitignored) and fill in real values.
# orchestration/.env must NEVER be committed.
# All values are consumed either by dlt (env var convention, see
# ingestion/*/pipeline.py) or by include/dbt_profiles/profiles.yml (via
# dbt's env_var() Jinja function).

# LOADER role — used by the dlt pipelines in dags/ingest_daily.py.
# PIPELINE_SVC is a dedicated Snowflake SERVICE user (see snowflake/setup.sql),
# not a person login — never point pipelines at your own Snowflake account.
DESTINATION__SNOWFLAKE__CREDENTIALS__DATABASE=RAW
DESTINATION__SNOWFLAKE__CREDENTIALS__USERNAME=PIPELINE_SVC
DESTINATION__SNOWFLAKE__CREDENTIALS__HOST=<account_identifier>
DESTINATION__SNOWFLAKE__CREDENTIALS__WAREHOUSE=MERCATO_WH
DESTINATION__SNOWFLAKE__CREDENTIALS__ROLE=LOADER
# Multi-line PEM content: wrap in double quotes with literal \n between lines
# (python-dotenv unescapes \n to a real newline when loading this file).
DESTINATION__SNOWFLAKE__CREDENTIALS__PRIVATE_KEY="<PEM content, \n-joined>"
DESTINATION__SNOWFLAKE__CREDENTIALS__PRIVATE_KEY_PASSPHRASE=<key_passphrase>

SOURCES__FOOTBALLDATA__API_TOKEN=<your_football-data.org_api_token>
KAGGLE_API_TOKEN=<your_kaggle_api_token>

# TRANSFORMER role — used by Cosmos/dbt in dags/transform.py and
# dags/full_refresh_monthly.py (same PIPELINE_SVC user and key pair, different
# Snowflake role — least-privilege is enforced per-role, not per-user).
SNOWFLAKE_ACCOUNT=<account_identifier>
SNOWFLAKE_USER=PIPELINE_SVC
SNOWFLAKE_ROLE=TRANSFORMER
SNOWFLAKE_PRIVATE_KEY="<PEM content, \n-joined>"
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=<key_passphrase>

# Makes the ingestion/ package (mounted by docker-compose.override.yml)
# importable from dags/ingest_daily.py.
PYTHONPATH=/usr/local/airflow
