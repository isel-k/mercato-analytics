# Copy to .dlt/secrets.toml (gitignored) and fill in real values.
# .dlt/secrets.toml must NEVER be committed.

[destination.snowflake.credentials]
database = "RAW"
username = "LOADER"
password = "<snowflake_password>"
host = "<account_identifier>"    # e.g. xy12345.eu-west-1
warehouse = "<warehouse_name>"
role = "LOADER"
