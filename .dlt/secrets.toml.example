# Copy to .dlt/secrets.toml (gitignored) and fill in real values.
# .dlt/secrets.toml must NEVER be committed.
# Run snowflake/setup.sql first — it creates the warehouse, database and
# LOADER role referenced below.

[destination.snowflake.credentials]
database = "RAW"
username = "<your_snowflake_login>"   # your personal Snowflake user, not the role
host = "<account_identifier>"         # from the Snowsight URL, e.g. abcd-xy12345
warehouse = "MERCATO_WH"
role = "LOADER"
# Key-pair auth (recommended, and required if your account enforces MFA on
# password logins — Snowflake trial accounts do by default):
#   openssl genrsa 2048 | openssl pkcs8 -topk8 -inform PEM -out .dlt/snowflake_loader_key.p8 -v2 aes256
#   openssl rsa -in .dlt/snowflake_loader_key.p8 -pubout -out /tmp/key.pub
#   -- then in Snowsight: ALTER USER <you> SET RSA_PUBLIC_KEY='<body of /tmp/key.pub>';
private_key_path = "<absolute_path_to>/.dlt/snowflake_loader_key.p8"
private_key_passphrase = "<key_passphrase>"

[sources.footballdata]
api_token = "<your_football-data.org_api_token>"   # free tier: https://www.football-data.org/client/register
